# =============================================================================
# XK Trading Floor Frontend - Environment Template (SAFE TO COMMIT)
# =============================================================================
# VITE_* variables are bundled into the client build — never put secrets here.
# =============================================================================

# API base URL (public)
VITE_API_BASE_URL=http://localhost:8000/api

# Site base path (use / for custom domain, /repo-name/ for GitHub Pages)
VITE_BASE_PATH=/

# Canonical site URL for SEO meta tags (public)
VITE_SITE_URL=http://localhost:5173

# Local backend URL for Vite dev proxy only
VITE_BACKEND_URL=http://localhost:8000
