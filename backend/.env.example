# =============================================================================
# XK Trading Floor - Backend Environment Template (SAFE TO COMMIT)
# =============================================================================
# Copy this file to `.env` and replace every placeholder with real values.
# NEVER commit `.env` files or paste real secrets into this example file.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=8000

# --- Database --------------------------------------------------------------
# Use a strong username/password in the connection string.
DB_URI=mongodb://localhost:27017/xktradingfloor
# For Atlas:  mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# --- Authentication (REQUIRED — use cryptographically random values) --------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# or:            openssl rand -base64 48
JWT_SECRET=replace_with_long_random_secret_min_64_chars
JWT_EXPIRED_IN=7d
COOKIE_EXPIRE_MS=86400000

# Domain used for auth cookies (e.g. xktradingfloor.com without protocol)
DOMAIN=localhost

# --- Application URLs ------------------------------------------------------
# NO trailing slash. NO ".com" on localhost.
SERVER=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Email (Brevo) — password reset & transactional mail ------------------
BREVO_API_KEY=replace_with_your_brevo_api_key
BREVO_FROM_NAME=XK Trading Floor
BREVO_FROM_EMAIL=noreply@xktradingfloor.com

# --- File Storage (Cloudflare R2 — currently used) -------------------------
R2_ACCOUNT_ID=your_r2_account_id
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=xktradingfloor
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_REGION=auto
R2_PUBLIC_DOMAIN=https://<pub-hash>.r2.dev

# --- Legacy (Mailchimp) — safe to leave unset ------------------------------
# We migrated to Brevo. Only needed if any Mailchimp code paths remain.
# MAILCHIMP_API_KEY=
# MAILCHIMP_SERVER_PREFIX=
# MAILCHIMP_AUDIENCE_ID=
# MAILCHIMP_FROM_NAME="XK Trading Floor"
# MAILCHIMP_FROM_EMAIL=info@xktradingfloor.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Do NOT set MASTER_PASSWORD in production (dev-only backdoor if ever needed).
# 2. Rotate JWT_SECRET and API keys immediately if they are ever exposed.
# 3. Use different secrets for development, staging, and production.
# 4. Restrict database IP access and enable MongoDB authentication in production.
